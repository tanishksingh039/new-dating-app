rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ========================================
    // SIMPLIFIED RULES FOR ADMIN PANEL
    // ========================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Admin access - allow all operations when no auth (admin panel)
    function isAdminAccess() {
      return request.auth == null;
    }
    
    // Firebase Auth admin access
    function isAdmin() {
      return isAuthenticated() && 
             (request.auth.token.email != null && 
              (request.auth.token.email.matches('.*admin.*@campusbound\\.com') ||
               request.auth.token.email in [
                 'admin@campusbound.com',
                 'support@campusbound.com',
                 'analytics@campusbound.com',
                 'finance@campusbound.com'
               ]));
    }
    
    // Super admin function
    function isSuperAdmin() {
      return isAuthenticated() && 
             request.auth.token.email == 'admin@campusbound.com';
    }
    
    // ========================================
    // USERS COLLECTION
    // ========================================
    
    match /users/{userId} {
      allow read: if true;
      allow create: if isOwner(userId) || isAdminAccess();
      allow update: if isOwner(userId) || isAdmin() || isAdminAccess();
      allow delete: if isAdmin() || isAdminAccess();
      
      match /{subcollection=**} {
        allow read, write: if isOwner(userId) || isAdminAccess();
      }
    }
    
    // ========================================
    // MATCHES COLLECTION
    // ========================================
    
    match /matches/{matchId} {
      allow read: if true;
      allow create: if isAuthenticated() || isAdminAccess();
      allow update: if isAuthenticated() || isAdminAccess();
      allow delete: if isAuthenticated() || isAdminAccess();
    }
    
    // ========================================
    // CHATS COLLECTION
    // ========================================
    
    match /chats/{chatId} {
      allow read: if isAuthenticated() || isAdminAccess();
      allow write: if isAuthenticated() || isAdminAccess();
      
      match /messages/{messageId} {
        allow read: if isAuthenticated() || isAdminAccess();
        allow create: if isAuthenticated() || isAdminAccess();
        allow update: if false;
        allow delete: if isAdminAccess();
      }
    }
    
    // ========================================
    // SWIPES COLLECTION
    // ========================================
    
    match /swipes/{swipeId} {
      allow read: if isAuthenticated() || isAdminAccess();
      allow create: if isAuthenticated() || isAdminAccess();
      allow update: if false;
      allow delete: if isAuthenticated() || isAdminAccess();
    }
    
    // ========================================
    // REWARDS SYSTEM
    // ========================================
    
    match /rewards_stats/{userId} {
      allow read: if true;
      allow write: if isOwner(userId) || isAdminAccess();
    }
    
    match /reward_incentives/{incentiveId} {
      allow read: if true;
      allow write: if isAdmin() || isAdminAccess();
    }
    
    match /reward_history/{historyId} {
      allow read: if true;
      allow write: if isAdminAccess();
    }
    
    match /daily_conversations/{userId}/{document=**} {
      allow read, write: if isOwner(userId) || isAdminAccess();
    }
    
    match /notifications/{notificationId} {
      allow read: if true;
      allow write: if isAdminAccess();
    }
    
    // ========================================
    // PAYMENT SYSTEM
    // ========================================
    
    match /payment_orders/{orderId} {
      allow read: if true;
      allow create: if isAuthenticated() || isAdminAccess();
      allow update: if isAuthenticated() || isAdminAccess();
      allow delete: if isAdminAccess();
    }
    
    match /payment_transactions/{transactionId} {
      allow read: if true;
      allow write: if isAdminAccess();
    }
    
    match /subscriptions/{userId} {
      allow read: if true;
      allow write: if isAdminAccess();
    }
    
    // ========================================
    // SPOTLIGHT SYSTEM
    // ========================================
    
    match /spotlight_bookings/{bookingId} {
      allow read: if true;
      allow create: if isAuthenticated() || isAdminAccess();
      allow update: if isAuthenticated() || isAdminAccess();
      allow delete: if isAdminAccess();
    }
    
    match /spotlight_transactions/{transactionId} {
      allow read: if true;
      allow create: if isAuthenticated() || isAdminAccess();
      allow update: if isAdminAccess();
      allow delete: if isAdminAccess();
    }
    
    // ========================================
    // SWIPE LIMIT SYSTEM
    // ========================================
    
    match /swipe_stats/{userId} {
      allow read: if true;
      allow create: if isOwner(userId) || isAdminAccess();
      allow update: if isOwner(userId) || isAdminAccess();
      allow delete: if isAdminAccess();
    }
    
    // ========================================
    // ADMIN COLLECTIONS
    // ========================================
    
    match /admin_logs/{logId} {
      allow read, write: if isAdmin() || isAdminAccess();
    }
    
    match /admin_sessions/{sessionId} {
      allow read, write: if isAdmin() || isAdminAccess();
    }
    
    match /system_stats/{statId} {
      allow read, write: if isAdmin() || isAdminAccess();
    }
    
    match /user_reports/{reportId} {
      allow read: if true;
      allow create: if isAuthenticated() || isAdminAccess();
      allow update: if isAdmin() || isAdminAccess();
      allow delete: if isAdminAccess();
    }
    
    // ========================================
    // CATCH-ALL FOR REMAINING COLLECTIONS
    // ========================================
    
    match /{document=**} {
      allow read, write: if isAdminAccess() || isAuthenticated();
    }
  }
}
